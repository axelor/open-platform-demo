{
  "name": "my-home",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@axelor/ui": "0.5.7",
    "dayjs": "^1.11.19",
    "immer": "^10.1.3",
    "jotai": "^2.15.2",
    "react": "~19.1.1",
    "react-dom": "~19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^22.18.5",
    "@types/react": "~19.1.13",
    "@types/react-dom": "~19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "sass": "1.77.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "dev": "vite --config vite-dev.config.ts",
    "clean": "rimraf dist",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --config vite-staging.config.ts",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,scss,html}\"",
    "test": "vitest",
    "lint": "eslint src"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@eslint/*"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
