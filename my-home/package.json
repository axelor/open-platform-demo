{
  "name": "my-home",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@axelor/ui": "0.6.1",
    "dayjs": "^1.11.19",
    "immer": "^11.1.3",
    "jotai": "^2.17.1",
    "react": "~19.2.4",
    "react-dom": "~19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.10",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "sass": "1.77.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite --config vite-dev.config.ts",
    "clean": "rimraf dist",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --config vite-staging.config.ts",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,scss,html}\"",
    "test": "vitest",
    "lint": "eslint src"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@eslint/*"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
